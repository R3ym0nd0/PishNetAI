{
  "rewrites": [
    { "source": "/", "destination": "/public/index.html" },
    { "source": "/assistant", "destination": "/public/assistant.html" },
    { "source": "/quiz", "destination": "/public/quiz.html" },
    { "source": "/login", "destination": "/public/login.html" },
    { "source": "/signup", "destination": "/public/signup.html" },
    { "source": "/reset-password", "destination": "/public/reset-password.html" },
    { "source": "/assistant.html", "destination": "/public/assistant.html" },
    { "source": "/quiz.html", "destination": "/public/quiz.html" },
    { "source": "/login.html", "destination": "/public/login.html" },
    { "source": "/signup.html", "destination": "/public/signup.html" },
    { "source": "/reset-password.html", "destination": "/public/reset-password.html" },
    { "source": "/assets/(.*)", "destination": "/public/assets/$1" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
